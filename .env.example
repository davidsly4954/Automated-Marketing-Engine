# ─── Database & Encryption ───────────────────────────────────────────────────
# Generate your own keys with: openssl rand -hex 16
POSTGRES_PASSWORD=
N8N_ENCRYPTION_KEY=

# ─── Content Generation ─────────────────────────────────────────────────────
# Required: Get your API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ─── Publishing Platforms (fill in as you sign up) ───────────────────────────

# Buffer (LinkedIn scheduling) — https://buffer.com/developers/api
BUFFER_ACCESS_TOKEN=
BUFFER_LINKEDIN_PROFILE_ID=

# Typefully (Twitter/X scheduling) — https://typefully.com/settings/api
TYPEFULLY_API_KEY=
TYPEFULLY_SOCIAL_SET_ID=

# Loops.so (Email newsletter) — https://app.loops.so/settings/api
LOOPS_API_KEY=
LOOPS_NEWSLETTER_TEMPLATE_ID=

# Dev.to (Cross-posting) — https://dev.to/settings/extensions
DEVTO_API_KEY=

# Hashnode (Cross-posting) — https://hashnode.com/settings/developer
HASHNODE_PAT=
HASHNODE_PUBLICATION_ID=
